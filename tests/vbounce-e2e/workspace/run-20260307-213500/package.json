{
  "name": "taskflow-api",
  "version": "1.0.0",
  "description": "TaskFlow API - Kanban-style task management with webhooks and full-text search",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "npx tsx --test test/**/*.test.ts",
    "test:coverage": "c8 npx tsx --test test/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "migrate": "tsx src/config/database.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.1.0",
    "pg": "^8.13.1",
    "uuid": "^11.0.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.12.0",
    "@types/pg": "^8.11.11",
    "@types/uuid": "^10.0.0",
    "c8": "^10.1.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
